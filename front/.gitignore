# ==========================================
# 🏢 IDE & Editors (어디서든 무시)
# ==========================================
.idea/
.vscode/
*.iml
*.iws
*.ipr
.history/

# ==========================================
# ⚛️ Node.js & React 핵심
# ==========================================
node_modules/
dist/
build/
.eslintcache
.stylelintcache

# ==========================================
# 💻 OS & Logs (시스템 쓰레기 방지)
# ==========================================
**/*.log
.DS_Store
Thumbs.db
desktop.ini
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ==========================================
# 🔐 Security & Env (환경 변수 - 절대 공유 금지)
# ==========================================
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
*.local

# ==========================================
# 📦 Dependency Lock (버전 동기화용 - 공유 권장)
# ==========================================
# 모든 lock 파일을 막기보다는 프로젝트에서 사용하는 것만 허용합니다.
*.lock
!package-lock.json
!yarn.lock

# ==========================================
# 🛠 Temporary
# ==========================================
.temp/
.swp
